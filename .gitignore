# WordPress Theme .gitignore

# System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDE/Editor Files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace
.phpintel/
nbproject/
*.swp
*.swo
*~

# Node.js (if you add npm/build tools later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Composer (if you add PHP dependencies)
/vendor/
composer.lock

# Build/Compiled Files
*.map
*.css.map
*.js.map
/dist/
/build/

# Logs
*.log
logs/
error_log
access_log

# Temporary Files
*.tmp
*.temp
*.cache
*.bak
*.backup
*~

# WordPress Specific
wp-config.php
wp-content/uploads/
wp-content/blogs.dir/
wp-content/upgrade/
wp-content/backup-db/
wp-content/cache/
wp-content/backups/

# Theme Specific - Local Development
screenshot-backup.png
/assets/images/local-testing/

# Environment Files
.env
.env.local
.env.*.local

# Sass/SCSS (if you add later)
.sass-cache/
*.css.map

# Minified files (keep originals in repo)
# Uncomment if you minify files:
# *.min.js
# *.min.css

# Archive files
*.zip
*.tar.gz
*.rar

# OS generated files
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# PHPStorm
.idea/

# Security - Never commit these!
*secret*
*private*
*.pem
*.key
*.cert
*.p12

# Local configuration
local-config.php
config.local.php